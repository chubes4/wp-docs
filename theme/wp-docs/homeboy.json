{
  "auto_cleanup": false,
  "changelog_target": "docs/CHANGELOG.md",
  "extensions": {
    "wordpress": {}
  },
  "id": "wp-docs",
  "remote_path": "/htdocs/wp-content/themes/wp-docs",
  "remote_url": "https://github.com/chubes4/wp-docs.git",
  "version_targets": [
    {
      "file": "style.css",
      "pattern": "(?m)^\\s*\\*?\\s*Version:\\s*([0-9.]+)"
    }
  ]
}
