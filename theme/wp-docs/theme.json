{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "760px",
      "wideSize": "1180px"
    },
    "color": {
      "defaultPalette": false,
      "palette": [
        {
          "slug": "ink",
          "name": "Ink",
          "color": "#f8fafc"
        },
        {
          "slug": "muted",
          "name": "Muted",
          "color": "#94a3b8"
        },
        {
          "slug": "surface",
          "name": "Surface",
          "color": "#020617"
        },
        {
          "slug": "surface-alt",
          "name": "Surface Alt",
          "color": "#0f172a"
        },
        {
          "slug": "border",
          "name": "Border",
          "color": "#1e293b"
        },
        {
          "slug": "accent",
          "name": "Accent",
          "color": "#7dd3fc"
        }
      ]
    },
    "spacing": {
      "spacingScale": {
        "steps": 0
      },
      "spacingSizes": [
        {
          "slug": "20",
          "name": "Small",
          "size": "0.75rem"
        },
        {
          "slug": "30",
          "name": "Medium",
          "size": "1rem"
        },
        {
          "slug": "40",
          "name": "Large",
          "size": "1.5rem"
        },
        {
          "slug": "50",
          "name": "X-Large",
          "size": "2.25rem"
        },
        {
          "slug": "60",
          "name": "2X-Large",
          "size": "3rem"
        }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "slug": "sans",
          "name": "Sans",
          "fontFamily": "Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, Segoe UI, sans-serif"
        },
        {
          "slug": "mono",
          "name": "Mono",
          "fontFamily": "SFMono-Regular, ui-monospace, Consolas, Liberation Mono, monospace"
        }
      ],
      "fontSizes": [
        {
          "slug": "small",
          "name": "Small",
          "size": "0.875rem"
        },
        {
          "slug": "normal",
          "name": "Normal",
          "size": "1rem"
        },
        {
          "slug": "large",
          "name": "Large",
          "size": "1.25rem"
        },
        {
          "slug": "x-large",
          "name": "X-Large",
          "size": "1.875rem"
        },
        {
          "slug": "xx-large",
          "name": "2X-Large",
          "size": "2.5rem"
        }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--surface)",
      "text": "var(--wp--preset--color--ink)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--sans)",
      "fontSize": "var(--wp--preset--font-size--normal)",
      "lineHeight": "1.7"
    },
    "elements": {
      "link": {
        "color": {
          "text": "var(--wp--preset--color--accent)"
        }
      },
      "heading": {
        "typography": {
          "lineHeight": "1.15"
        }
      }
    }
  },
  "templateParts": [
    {
      "name": "header",
      "title": "Header",
      "area": "header"
    },
    {
      "name": "footer",
      "title": "Footer",
      "area": "footer"
    }
  ]
}
